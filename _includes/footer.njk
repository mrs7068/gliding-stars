<footer class="site-footer">

  <div class="footer-top">

    <div class="footer-inner">
      <div class="footer-grid">

        <!-- COLUMN 1: LOGO -->
        <div class="footer-col footer-logo">
          <a href="/" class="footer-logo">
            <img src="/assets/images/logo.png" alt="Gliding Stars logo">
          </a>
        </div>

        <!-- COLUMN 2: MAILING ADDRESS -->
        <div class="footer-col">
          <p class="footer-heading">Mailing Address</p>
          <p>Gliding Stars of Erie, Inc.<br>
          PO Box 11304<br>
          Erie, PA 16514</p>
        </div>

        <!-- COLUMN 3: CONTACT + SOCIALS -->
        <div class="footer-col">
          <p class="footer-heading">Contact</p>

          <p>
            <a href="mailto:glidingstarsoferie@gmail.com">
              glidingstarsoferie@gmail.com
            </a>
          </p>

          <p>
            <a href="tel:18145808151">
              814-580-8151
            </a>
          </p>

          <div class="footer-socials">
            <a href="https://www.facebook.com/groups/91702421633/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg class="icon" viewBox="0 0 24 24">
                <path d="M22 12a10 10 0 1 0-11.6 9.9v-7h-2.7v-2.9h2.7V9.8c0-2.7 1.6-4.2 4-4.2 1.2 0 2.4.2 2.4.2v2.6h-1.3c-1.3 0-1.7.8-1.7 1.6v1.9h2.9l-.5 2.9h-2.4v7A10 10 0 0 0 22 12z"/>
              </svg>
            </a>

            <a href="https://www.instagram.com/glidingstarsoferie/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg class="icon" viewBox="0 0 24 24">
                <path d="M7 2C4.2 2 2 4.2 2 7v10c0 2.8 2.2 5 5 5h10c2.8 0 5-2.2
                5-5V7c0-2.8-2.2-5-5-5H7zm5 5a5 5 0 1 1 0 10 5 5 0 0
                1 0-10zm6.5-.8a1.2 1.2 0 1 1-2.4 0 1.2 1.2 0 0
                1 2.4 0z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- COLUMN 4: ICE LOCATION -->
        <div class="footer-col">
          <p class="footer-heading">Ice Location</p>
            <p class="footer-link-block">
              <a href="https://maps.app.goo.gl/v3A6BqgMfSiyFL2x7" target="_blank" rel="noopener noreferrer">
                Mercyhurst Ice Center<br>
                501 E 38th St<br>
                Erie, PA 16504
              </a>
            </p>
        </div>

      </div>
    </div>

  </div>

  <div class="footer-bottom">

    <div class="footer-inner footer-bottom-inner">

      <p class="copyright">
        © {{ site.year }} Gliding Stars of Erie, Inc. All Rights Reserved.
      </p>

      <nav class="footer-nav">
        {% for item in navigation %}
          <a href="{{ item.url }}">{{ item.name }}</a>
        {% endfor %}
      </nav>

    </div>

  </div>

</footer>