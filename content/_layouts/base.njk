<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
      {% if title == "Home" %}
        Gliding Stars of Erie
      {% else %}
        {{ title }} | Gliding Stars of Erie
      {% endif %}
    </title>

  <link rel="stylesheet" href="{{ '/css/style.css' | url }}?v={{ build }}">
  <link rel="icon" href="{{ '/assets/images/favicon.svg' | url }}" type="image/svg+xml">
  <link rel="alternate icon" href="{{ '/assets/images/favicon.svg' | url }}">
  <link rel="apple-touch-icon" href="{{ '/assets/images/favicon.svg' | url }}">

  <meta name="description" content="Gliding Stars of Erie is an adaptive ice skating program helping individuals with disabilities grow through skating.">

  <meta property="og:title" content="{% if page.url == '/' %}Gliding Stars of Erie{% else %}{{ title }} | Gliding Stars of Erie{% endif %}">
  <meta property="og:description" content="Adaptive ice skating program in Erie, PA.">
  <meta property="og:image" content="{{ '/assets/images/logo.png' | url }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ page.url | url }}">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{% if page.url == '/' %}Gliding Stars of Erie{% else %}{{ title }} | Gliding Stars of Erie{% endif %}">
  <meta name="twitter:description" content="Adaptive ice skating program in Erie, PA.">
  <meta name="twitter:image" content="{{ '/assets/images/logo.png' | url }}">
</head>

<body class="{% if page.url == '/' %}home{% endif %}">

<header class="site-header">
  {% include "nav.njk" %}
</header>

<main>
  {% block content %}
    {{ content | safe }}
  {% endblock %}
</main>

{% include "footer.njk" %}

<script src="{{ '/js/main.js' | url }}?v={{ build }}" defer></script>

</body>
</html>